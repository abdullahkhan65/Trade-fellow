# ============================================================
# PropTrader — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# Supabase — create a free project at https://supabase.com
# Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# Optional: MetaApi — for real-time MT5/MT4 sync
# Get your token at https://app.metaapi.cloud
# Users enter their own MetaApi credentials in the app settings.
# METAAPI_TOKEN is only needed if you use server-side sync.
# ============================================================
# METAAPI_TOKEN=your-metaapi-token

# ============================================================
# SETUP STEPS:
# 1. Go to https://supabase.com and create a free project
# 2. Go to SQL Editor and run the contents of supabase/migrations/001_init.sql
# 3. Copy this file to .env.local and fill in the values above
# 4. Run: npm run dev
# 5. Deploy to Vercel and add the same env vars in Vercel dashboard
# ============================================================
